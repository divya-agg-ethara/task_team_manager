# =============================================================================
# Team Task Manager — API (server)
# Copy to .env for local development. On Railway, set these in the service Variables.
# =============================================================================

# PostgreSQL connection string (Railway: use the Postgres plugin DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# JWT signing secret — use a long random string in production (32+ characters)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Token lifetime (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# Server port (Railway injects PORT automatically — do not hardcode in production)
PORT=4000

# Primary frontend URL for CORS (production: your deployed client, e.g. Vercel or Railway)
CLIENT_URL=http://localhost:3000

# Optional: additional CORS origins, comma-separated
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-frontend.up.railway.app

# Node environment
NODE_ENV=development
